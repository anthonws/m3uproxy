# Your M3U playlist URL (required)
M3U_URL="https://your-m3u-provider.example.com/playlist.m3u"

# Your timezone (e.g. Europe/Lisbon, America/New_York)
TZ=Europe/Lisbon

# --- Optional ---
# PROXY_PORT=7654
# DEFAULT_UA="Mozilla/5.0 (X11; Linux x86_64; rv:149.0) Gecko/20100101 Firefox/149.0"
# PLAYLIST_TTL=86400
# CONNECT_TIMEOUT=5
# STREAM_TIMEOUT=10
# PLAYLIST_TIMEOUT=20
# FETCH_RETRIES=2
# CHUNKLIST_TTL=2     # seconds to cache HLS chunklists (0 disables)

# --- Connection tuning (defaults suit a handful of users; raise for larger deployments) ---
# POOL_MAXSIZE=32     # keep-alive connections kept per upstream host
# POOL_NUM_POOLS=20   # number of distinct upstream hosts pooled
# MAX_CONCURRENT=0    # cap on in-flight requests (0 = unlimited); set e.g. 100 to bound load
# CLIENT_TIMEOUT=30   # seconds an idle keep-alive client connection is held open

# --- Logging ---
# LOG_LEVEL=INFO      # DEBUG | INFO | WARNING | ERROR
